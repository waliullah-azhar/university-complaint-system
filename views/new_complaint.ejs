<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>University Complaint System - Submit Complaint</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #F3F4F6;
        }

        .header {
            background-color: #1E3A8A;
            color: white;
            padding: 15px;
            text-align: center;
            font-size: 22px;
            font-weight: bold;
        }

        .complaint-card {
            margin-top: 30px;
            padding: 30px;
            border-radius: 10px;
            background-color: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .btn-success {
            background-color: #10B981;
            border: none;
        }

        .btn-success:hover {
            background-color: #047857;
        }

        .btn-secondary {
            background-color: #6B7280;
            border: none;
        }

        .btn-secondary:hover {
            background-color: #4B5563;
        }
    </style>
</head>
<body>

<div class="header">
    University Complaint System
</div>

<div class="container">
    <div class="complaint-card">
        <h4 class="mb-4">Submit New Complaint</h4>
        <form action="/complaint/new" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input type="text" name="title" class="form-control" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="4" required></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Category</label>
                <input type="text" name="category" class="form-control" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Priority</label>
                <select name="priority" class="form-select" required>
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Upload File (Optional)</label>
                <input type="file" name="file" class="form-control">
            </div>

            <div class="d-flex justify-content-start">
                <button type="submit" class="btn btn-success">Submit Complaint</button>
                <a href="/dashboard" class="btn btn-secondary ms-2">Back to Dashboard</a>
            </div>
        </form>
    </div>
</div>

</body>
</html>
