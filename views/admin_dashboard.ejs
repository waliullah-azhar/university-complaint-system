<!DOCTYPE html>
<html>
<head>
  <title>University Complaint System - Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #F3F4F6;
    }

    .header {
      background-color: #1E3A8A;
      color: white;
      padding: 15px;
      text-align: center;
      font-size: 22px;
      font-weight: bold;
    }

    .dashboard-container {
      margin-top: 30px;
    }

    .table thead {
      background-color: #1E3A8A;
      color: white;
    }

    .badge-pending {
      background-color: #F59E0B;
    }

    .badge-progress {
      background-color: #3B82F6;
    }

    .badge-resolved {
      background-color: #16A34A;
    }

    .badge-high {
      background-color: #DC2626;
    }

    .badge-medium {
      background-color: #F59E0B;
    }

    .badge-low {
      background-color: #16A34A;
    }

    .btn-success {
      background-color: #3B82F6;
      border: none;
    }

    .btn-success:hover {
      background-color: #1E40AF;
    }
  </style>
</head>

<body>

<div class="header">
  University Complaint System - Admin Panel
</div>

<div class="container dashboard-container">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4>All Complaints</h4>
    <a href="/logout" class="btn btn-danger">Logout</a>
  </div>

  <div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
      <thead>
        <tr>
          <th>User</th>
          <th>Email</th>
          <th>Title</th>
          <th>Description</th>
          <th>Category</th>
          <th>File</th>
          <th>Priority</th>
          <th>Status</th>
          <th>Admin Response</th>
          <th>Updated</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>

        <% complaints.forEach(c => { %>
          <tr>
            <td><%= c.user_name %></td>
            <td><%= c.user_email %></td>
            <td><%= c.title %></td>
            <td><%= c.description %></td>
            <td><%= c.category || '-' %></td>

            <td>
              <% if(c.file_url) { %>
                <a href="<%= c.file_url %>" target="_blank" class="btn btn-sm btn-info">View</a>
              <% } else { %>
                -
              <% } %>
            </td>

            <!-- Priority Badge -->
            <td>
              <% if(c.priority === 'High') { %>
                <span class="badge badge-high">High</span>
              <% } else if(c.priority === 'Medium') { %>
                <span class="badge badge-medium">Medium</span>
              <% } else { %>
                <span class="badge badge-low">Low</span>
              <% } %>
            </td>

            <!-- Status Badge -->
            <td>
              <% if(c.status === 'Resolved') { %>
                <span class="badge badge-resolved">Resolved</span>
              <% } else if(c.status === 'In Progress') { %>
                <span class="badge badge-progress">In Progress</span>
              <% } else { %>
                <span class="badge badge-pending">Pending</span>
              <% } %>
            </td>

            <td><%= c.admin_response || '-' %></td>
            <td><%= new Date(c.updated_at).toLocaleString() %></td>

            <td>
              <form action="/admin/update/<%= c.id %>" method="POST">
                <select name="status" class="form-select mb-1">
                  <option value="Pending" <%= c.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                  <option value="In Progress" <%= c.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                  <option value="Resolved" <%= c.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                </select>

                <input type="text"
                       name="admin_response"
                       class="form-control mb-1"
                       placeholder="Add response"
                       value="<%= c.admin_response || '' %>">

                <button type="submit" class="btn btn-sm btn-success w-100">
                  Update
                </button>
              </form>
            </td>

          </tr>
        <% }) %>

      </tbody>
    </table>
  </div>

</div>

</body>
</html>
