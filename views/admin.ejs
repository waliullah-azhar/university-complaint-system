<!DOCTYPE html>
<html>
<head>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>Admin Panel</title>
</head>
<body class="bg-light">
<div class="container mt-5">
  <h2>Admin Panel</h2>
  <a href="/logout" class="btn btn-danger mb-3">Logout</a>

  <table class="table table-striped">
    <tr>
      <th>User</th>
      <th>Email</th>
      <th>Title</th>
      <th>Description</th>
      <th>Status</th>
      <th>Admin Response</th>
      <th>Updated At</th>
      <th>Action</th>
    </tr>
    <% complaints.forEach(c => { %>
      <tr>
        <td><%= c.user_name %></td>
        <td><%= c.user_email %></td>
        <td><%= c.title %></td>
        <td><%= c.description %></td>
        <td><%= c.status %></td>
        <td><%= c.admin_response || '' %></td>
        <td><%= new Date(c.updated_at).toLocaleString() %></td>
        <td>
          <form method="POST" action="/update-status">
            <input type="hidden" name="id" value="<%= c.id %>">
            <select name="status" class="form-select mb-1">
              <option value="Pending" <%= c.status=='Pending'?'selected':'' %>>Pending</option>
              <option value="In Progress" <%= c.status=='In Progress'?'selected':'' %>>In Progress</option>
              <option value="Resolved" <%= c.status=='Resolved'?'selected':'' %>>Resolved</option>
            </select>
            <textarea name="admin_response" class="form-control mb-1" placeholder="Write response..."><%= c.admin_response %></textarea>
            <button type="submit" class="btn btn-success btn-sm">Update</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
</div>
</body>
</html><h2>Admin Panel</h2>

<ul>
<% complaints.forEach(c => { %>
  <li>
    <%= c.title %> - <%= c.status %>

    <form method="POST" action="/update-status">
      <input type="hidden" name="id" value="<%= c.id %>">
      <select name="status">
        <option>Pending</option>
        <option>In Progress</option>
        <option>Resolved</option>
      </select>
      <button>Update</button>
    </form>
  </li>
<% }) %>
</ul>
